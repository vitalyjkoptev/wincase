# =====================================================
# WINCASE CRM v4.0 — Environment Configuration
# Immigration Bureau, Warsaw, Poland
# =====================================================

# ==========================================
# APPLICATION
# ==========================================
APP_NAME="WinCase CRM"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://api.wincase.pro
APP_TIMEZONE=Europe/Warsaw
APP_LOCALE=pl

# ==========================================
# DATABASE (MySQL 8.4)
# ==========================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wincase_crm
DB_USERNAME=wincase
DB_PASSWORD=YOUR_STRONG_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ==========================================
# REDIS 7
# ==========================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ==========================================
# AUTH (Sanctum)
# ==========================================
SANCTUM_STATEFUL_DOMAINS=wincase.pro,admin.wincase.pro
SANCTUM_TOKEN_EXPIRATION=10080

# ==========================================
# WEBSOCKET (Laravel Reverb)
# ==========================================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=wincase-crm
REVERB_APP_KEY=wincase-key
REVERB_APP_SECRET=wincase-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

# ==========================================
# MAIL (SendGrid / SMTP)
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=YOUR_SENDGRID_API_KEY
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=crm@wincase.pro
MAIL_FROM_NAME="WinCase CRM"

# ==========================================
# SMS (SMSApi.pl — primary, Twilio — fallback)
# ==========================================
SMS_PROVIDER=smsapi
SMSAPI_TOKEN=YOUR_SMSAPI_TOKEN
TWILIO_SID=YOUR_TWILIO_SID
TWILIO_TOKEN=YOUR_TWILIO_TOKEN
TWILIO_FROM=+48XXXXXXXXX

# ==========================================
# WHATSAPP (Business Cloud API)
# ==========================================
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN
WHATSAPP_VERIFY_TOKEN=YOUR_VERIFY_TOKEN

# ==========================================
# TELEGRAM BOT
# ==========================================
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_ADMIN_CHAT_ID=YOUR_ADMIN_CHAT_ID
TELEGRAM_WEBHOOK_URL=https://api.wincase.pro/api/v1/telegram/webhook

# ==========================================
# FIREBASE (FCM Push)
# ==========================================
FIREBASE_PROJECT_ID=wincase-crm
FIREBASE_CREDENTIALS_PATH=/var/www/html/storage/firebase-credentials.json

# ==========================================
# AI REWRITER (News Pipeline)
# ==========================================
AI_REWRITER_PROVIDER=anthropic
AI_REWRITER_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ==========================================
# NEWS PIPELINE — Target Sites
# ==========================================
POLANDPULSE_URL=https://polandpulse.news
POLANDPULSE_API_KEY=YOUR_WP_APPLICATION_PASSWORD
POLANDPULSE_WP_USER=admin
WINCASE_BLOG_URL=https://wincase.pro/api/v1/blog
WINCASE_BLOG_API_KEY=YOUR_BLOG_API_KEY

# Warsaw Daily
WARSAWDAILY_URL=https://warsawdaily.org
WARSAWDAILY_WP_USER=wincase_admin
WARSAWDAILY_WP_PASSWORD=YOUR_WP_APPLICATION_PASSWORD

# EuroGaming Post
EUROGAMING_URL=https://eurogamingpost.com
EUROGAMING_WP_USER=admin
EUROGAMING_WP_PASSWORD=YOUR_WP_APPLICATION_PASSWORD

# TechPulse
TECHPULSE_URL=https://techpulse.news
TECHPULSE_WP_USER=admin
TECHPULSE_WP_PASSWORD=YOUR_WP_APPLICATION_PASSWORD

# BizEurope
BIZEUROPE_URL=https://bizeurope.news
BIZEUROPE_WP_USER=admin
BIZEUROPE_WP_PASSWORD=YOUR_WP_APPLICATION_PASSWORD

# SportPulse
SPORTPULSE_URL=https://sportpulse.news
SPORTPULSE_WP_USER=admin
SPORTPULSE_WP_PASSWORD=YOUR_WP_APPLICATION_PASSWORD

# Diaspora
DIASPORA_URL=https://diaspora.news
DIASPORA_WP_USER=admin
DIASPORA_WP_PASSWORD=YOUR_WP_APPLICATION_PASSWORD

# TrendWatch
TRENDWATCH_URL=https://trendwatch.news
TRENDWATCH_WP_USER=admin
TRENDWATCH_WP_PASSWORD=YOUR_WP_APPLICATION_PASSWORD

# ==========================================
# GOOGLE — shared OAuth 2.0 (GA4, GSC, Ads, YouTube, GBP)
# ==========================================
# Create at: https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Client ID → Desktop app
# Get refresh token: php artisan google:oauth-setup
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Maps / Places API key (for GBP reviews)
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=ChIJd6uSdZnNHkcRBIQUdlchCgM

# GA4 — property IDs for each domain (from GA4 admin panel)
GA4_PROPERTY_WINCASE_PRO=
GA4_PROPERTY_LEGALIZATION=
GA4_PROPERTY_JOB=
GA4_PROPERTY_ORG=

# ==========================================
# ADVERTISING PLATFORMS
# ==========================================
# Google Ads (needs developer token from ads.google.com/aw/apicenter)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Meta Ads (Facebook/Instagram)
META_ACCESS_TOKEN=YOUR_LONG_LIVED_TOKEN
META_AD_ACCOUNT_ID=act_XXXXXXXXX
META_APP_ID=YOUR_APP_ID
META_APP_SECRET=YOUR_APP_SECRET
META_PIXEL_ID=YOUR_PIXEL_ID

# TikTok Ads
TIKTOK_ACCESS_TOKEN=YOUR_TIKTOK_TOKEN
TIKTOK_ADVERTISER_ID=YOUR_ADVERTISER_ID
TIKTOK_PIXEL_ID=YOUR_PIXEL_ID

# LinkedIn Ads
LINKEDIN_ACCESS_TOKEN=YOUR_LINKEDIN_TOKEN
LINKEDIN_AD_ACCOUNT_ID=YOUR_AD_ACCOUNT_ID

# Twitter/X Ads
TWITTER_API_KEY=YOUR_API_KEY
TWITTER_API_SECRET=YOUR_API_SECRET
TWITTER_ACCESS_TOKEN=YOUR_ACCESS_TOKEN

# ==========================================
# SEO TOOLS
# ==========================================
# GSC + GA4 use shared Google OAuth above (GOOGLE_CLIENT_ID, GOOGLE_REFRESH_TOKEN)
# No separate credentials files needed

# Ahrefs
AHREFS_API_KEY=YOUR_AHREFS_API_KEY

# ==========================================
# SOCIAL MEDIA (8 platforms)
# ==========================================
# Facebook
FACEBOOK_PAGE_ID=YOUR_PAGE_ID
FACEBOOK_ACCESS_TOKEN=YOUR_PAGE_ACCESS_TOKEN

# Instagram
INSTAGRAM_BUSINESS_ID=YOUR_INSTAGRAM_BUSINESS_ID

# YouTube
YOUTUBE_CHANNEL_ID=YOUR_CHANNEL_ID
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# LinkedIn (Company)
LINKEDIN_COMPANY_ID=YOUR_COMPANY_ID

# TikTok (Social)
TIKTOK_BUSINESS_ID=YOUR_BUSINESS_ID

# Twitter/X
TWITTER_BEARER_TOKEN=YOUR_BEARER_TOKEN

# Pinterest
PINTEREST_ACCESS_TOKEN=YOUR_PINTEREST_TOKEN
PINTEREST_BOARD_ID=YOUR_BOARD_ID

# Telegram Channel
TELEGRAM_CHANNEL_ID=@your_channel

# ==========================================
# PAYMENT SYSTEMS
# ==========================================
# Stripe (international card payments)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=pln

# Przelewy24 (Polish banks, BLIK)
P24_MERCHANT_ID=
P24_POS_ID=
P24_API_KEY=
P24_CRC=
P24_SANDBOX=false

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_SANDBOX=false
PAYPAL_CURRENCY=PLN

# ==========================================
# n8n WORKFLOW ENGINE
# ==========================================
N8N_URL=http://n8n:5678
N8N_PUBLIC_URL=https://n8n.wincase.pro
N8N_USER=admin
N8N_PASSWORD=YOUR_N8N_PASSWORD
N8N_WEBHOOK_URL=https://n8n.wincase.pro/webhook

# ==========================================
# FILE STORAGE
# ==========================================
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=

# ==========================================
# LOGGING
# ==========================================
LOG_CHANNEL=daily
LOG_LEVEL=info
LOG_DAYS=30

# ==========================================
# CORS
# ==========================================
CORS_ALLOWED_ORIGINS=https://admin.wincase.pro,https://wincase.pro

# ---------------------------------------------------------------
# Аннотация (RU):
# .env шаблон — 80+ переменных окружения для WinCase CRM v4.0.
# Секции: App, Database, Redis, Auth, WebSocket, Mail, SMS, WhatsApp,
# Telegram, Firebase, AI (Anthropic/OpenAI), News targets, 5 рекламных
# платформ, SEO (GSC/GA4/Ahrefs), 8 соцсетей, n8n, Storage, Logging.
# Файл: .env.example
# ---------------------------------------------------------------
