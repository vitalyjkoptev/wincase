# =====================================================
# FILE: .env.example
# WINCASE CRM v4.0 — Environment Variables
# =====================================================

# =====================================================
# APP
# =====================================================
APP_NAME="WinCase CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.wincase.pro
APP_TIMEZONE=Europe/Warsaw

# =====================================================
# DATABASE (MySQL 8.4 LTS)
# =====================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wincase_crm
DB_USERNAME=wincase
DB_PASSWORD=
DB_ROOT_PASSWORD=

# =====================================================
# REDIS (Cache + Queue + Sessions + Reverb)
# =====================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# =====================================================
# SANCTUM
# =====================================================
SANCTUM_STATEFUL_DOMAINS=api.wincase.pro,wincase.pro

# =====================================================
# REVERB (WebSocket)
# =====================================================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=wincase
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

# =====================================================
# MAIL (SendGrid)
# =====================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=crm@wincase.pro
MAIL_FROM_NAME="WinCase CRM"

# =====================================================
# GOOGLE APIs
# =====================================================
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

GOOGLE_SEARCH_CONSOLE_CREDENTIALS=
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_PLACE_ID=
GOOGLE_API_KEY=

# =====================================================
# META (Facebook / Instagram)
# =====================================================
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PIXEL_ID=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=
INSTAGRAM_BUSINESS_ID=

# =====================================================
# TIKTOK
# =====================================================
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_PIXEL_ID=

# =====================================================
# PINTEREST
# =====================================================
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_AD_ACCOUNT_ID=

# =====================================================
# SEO
# =====================================================
AHREFS_API_TOKEN=

# =====================================================
# SOCIAL PLATFORMS
# =====================================================
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=
THREADS_ACCESS_TOKEN=

# =====================================================
# REVIEWS
# =====================================================
TRUSTPILOT_API_KEY=
TRUSTPILOT_BUSINESS_ID=

# =====================================================
# n8n
# =====================================================
N8N_HOST=n8n.wincase.pro
N8N_USER=admin
N8N_PASSWORD=
N8N_URL=http://n8n:5678
N8N_API_KEY=

# =====================================================
# STORAGE
# =====================================================
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=wincase-documents

# =====================================================
# FIREBASE (Flutter Push Notifications)
# =====================================================
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=

# =====================================================
# WHATSAPP BUSINESS
# =====================================================
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ---------------------------------------------------------------
# Аннотация (RU):
# .env.example — все переменные окружения WINCASE CRM v4.0.
# 15 секций: App, DB, Redis, Sanctum, Reverb, Mail,
# Google (Ads/GSC/GA4/Maps), Meta, TikTok, Pinterest,
# SEO (Ahrefs), Social (YouTube/Telegram/LinkedIn/Threads),
# Reviews (Trustpilot), n8n, Storage (S3), Firebase, WhatsApp.
# Файл: .env.example
# ---------------------------------------------------------------
