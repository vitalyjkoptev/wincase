                                {
                                    "id": "1f950440",
                                    "settings": {
                                        "ekit_accordion_items": [
                                            {
                                                "acc_title": "What immigration services do you provide?",
                                                "acc_content": "<p data-pm-slice=\"0 0 []\">We offer visa consultation, application support, document preparation, permanent residency, citizenship guidance, and reapplication assistance.<\/p>",
                                                "ekit_acc_is_active": "yes",
                                                "_id": "b97d72d"
                                            },
                                            {
                                                "acc_title": "How do I know which visa is right for me?",
                                                "acc_content": "<p data-pm-slice=\"0 0 []\">Our experts assess your background and goals to recommend the most suitable visa option.<\/p>",
                                                "_id": "b649edd"
                                            },
                                            {
                                                "acc_title": "How long does the visa process take?",
                                                "acc_content": "<p data-pm-slice=\"0 0 []\">Processing times vary by country and visa type. We provide estimated timelines after assessment.<\/p>",
                                                "_id": "2879ae4"
                                            },
                                            {
                                                "acc_title": "Do you guarantee visa approval?",
                                                "acc_content": "<p data-pm-slice=\"0 0 []\">No consultant can guarantee approval, but we ensure accurate preparation and compliance to maximize success.<\/p>",
                                                "_id": "6dd2fbc"
                                            },
                                            {
                                                "acc_title": "Can you help if my visa was refused?",
                                                "acc_content": "<p data-pm-slice=\"0 0 []\">Yes, we assist with appeals, refusals, and reapplications.<\/p>",
                                                "_id": "b20e2fa"
                                            },
                                            {
                                                "acc_title": "Which countries do you support?",
                                                "acc_content": "<p data-pm-slice=\"0 0 []\">We support applications for Canada, Australia, UK, Europe, and other major destinations.<\/p>",
